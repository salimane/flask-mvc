# Required environment variables — copy to .env and fill in values before running.

# REQUIRED: Flask secret key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# OPTIONAL: Flask environment (development | testing | production). Default: development
FLASK_ENV=development

# OPTIONAL: Port to bind the dev server to. Default: 8080
PORT=8080
